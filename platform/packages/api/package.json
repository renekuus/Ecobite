{
  "name": "@ecobit/api",
  "version": "0.1.0",
  "private": true,
  "description": "EcoBite REST API — Fastify + Node.js",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "fastify": "^4.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "pg": "^8.0.0",
    "ioredis": "^5.0.0",
    "zod": "^3.0.0",
    "@ecobit/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/pg": "^8.0.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
