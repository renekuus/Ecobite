NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://ecobit:password@localhost:5432/ecobit_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_in_production_too
