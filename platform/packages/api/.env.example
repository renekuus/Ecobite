JWT_REFRESH_EXPIRES_IN=30d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# AWS
AWS_REGION=eu-north-1
AWS_S3_ASSETS_BUCKET=ecobit-assets
AWS_S3_DOCUMENTS_BUCKET=ecobit-documents
AWS_SQS_ORDERS_QUEUE_URL=https://sqs.eu-north-1.amazonaws.com/...
