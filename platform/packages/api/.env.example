NODE_ENV=development
PORT=3001
# HOST=0.0.0.0  # default; uncomment to override

# ── PostgreSQL (required) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://ecobit:password@localhost:5432/ecobit_dev

# ── Redis (optional in dev) ────────────────────────────────────────────────────
# If unset the API starts in degraded mode: no caching, no courier location.
# All other endpoints work normally.
REDIS_URL=redis://localhost:6379

# ── JWT (required) ────────────────────────────────────────────────────────────
# Use any long random string. In prod generate with: openssl rand -base64 64
JWT_SECRET=change_me_in_production_min32chars_xxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_in_production_too_min32chars_xxxxx
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Admin credentials (provisional) ───────────────────────────────────────────
# @provisional — replace with a proper admin_users table in a future migration.
# These are used by POST /api/v1/auth/login when email matches.
ADMIN_EMAIL=admin@ecobitedemo.fi
ADMIN_PASSWORD=devadminpassword

# ── CORS (production only) ────────────────────────────────────────────────────
# In development all origins are allowed. Set this in production:
# CORS_ORIGIN=https://dashboard.ecobitehki.fi

# ── Stripe (not required for local dev) ───────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── AWS (not required for local dev) ──────────────────────────────────────────
# AWS_REGION=eu-north-1
# AWS_S3_ASSETS_BUCKET=ecobit-assets
# AWS_S3_DOCUMENTS_BUCKET=ecobit-documents
# AWS_SQS_ORDERS_QUEUE_URL=https://sqs.eu-north-1.amazonaws.com/...
